<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.Events"
             Title="Campus Events"
             BackgroundColor="{StaticResource BackgroundLight}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#1F4E8C</Color>
            <Color x:Key="TextPrimary">#0F172A</Color>
            <Color x:Key="TextSecondary">#64748B</Color>
            <Color x:Key="BackgroundLight">#EFF6FF</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="BorderLight">#E2E8F0</Color>
            <Color x:Key="SearchBackground">#F1F5F9</Color>

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="12" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid WidthRequest="402"
          HeightRequest="874"
          HorizontalOptions="Center"
          RowDefinitions="Auto,Auto,*,Auto">

        <!-- Top bar -->
        <Grid Grid.Row="0"
              Padding="12,10"
              BackgroundColor="{StaticResource CardBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Text="←"
                    BackgroundColor="Transparent"
                    BorderColor="Transparent"
                    Clicked="Back_Clicked"
                    HorizontalOptions="Start"
                    VerticalOptions="Center" />

            <Label Grid.Column="1"
                   Text="Campus Events"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="{StaticResource TextPrimary}" />
        </Grid>

        <!-- Search + Filters -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="16,8"
                             Spacing="8">

            <Border BackgroundColor="{StaticResource SearchBackground}"
                    StrokeThickness="0"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Image Source="https://placehold.co/18x18"
                           WidthRequest="18"
                           HeightRequest="18"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Placeholder="Search campus events"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <HorizontalStackLayout Spacing="8">
                <Button Text="Date"
                        Clicked="Filter_Clicked"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Text="Category"
                        Clicked="Filter_Clicked"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Text="Location"
                        Clicked="Filter_Clicked"
                        Style="{StaticResource FilterButtonStyle}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Events list -->
        <CollectionView x:Name="EventsList"
                        Grid.Row="2"
                        SelectionMode="None"
                        Margin="16"
                        ItemSizingStrategy="MeasureAllItems">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}"
                            Margin="0,6">
                        <Grid ColumnDefinitions="96,*"
                              ColumnSpacing="12">
                            <Image Source="{Binding ImageUrl}"
                                   WidthRequest="96"
                                   HeightRequest="96"
                                   Aspect="AspectFill" />

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="{Binding Category}"
                                       TextColor="{Binding CategoryColor}"
                                       FontSize="12"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />

                                <Label Text="{Binding DateText}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />

                                <Label Text="{Binding Location}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />

                                <Button Text="{Binding ActionText}"
                                        BackgroundColor="{Binding ActionColor}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="36"
                                        Margin="0,8,0,0"
                                        Clicked="Register_Clicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom navigation -->
        <Grid Grid.Row="3"
              BackgroundColor="White"
              Padding="12"
              ColumnDefinitions="*,*,Auto,*,*">

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0"
                                 HorizontalOptions="Center">
                <Image Source="https://placehold.co/20x20"
                       WidthRequest="20"
                       HeightRequest="20" />
                <Label Text="Home"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Events -->
            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center">
                <Image Source="https://placehold.co/20x20/3B82F6/FFFFFF"
                       WidthRequest="24"
                       HeightRequest="24" />
                <Label Text="Events"
                       FontSize="12"
                       TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>

            <!-- Center spacer -->
            <BoxView Grid.Column="2"
                     WidthRequest="88"
                     BackgroundColor="Transparent" />

            <!-- History -->
            <VerticalStackLayout Grid.Column="3"
                                 HorizontalOptions="Center">
                <Image Source="https://placehold.co/20x20"
                       WidthRequest="20"
                       HeightRequest="20"
                       Opacity="0.6" />
                <Label Text="History"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Profile -->
            <VerticalStackLayout Grid.Column="4"
                                 HorizontalOptions="Center">
                <Image Source="https://placehold.co/20x20"
                       WidthRequest="20"
                       HeightRequest="20"
                       Opacity="0.6" />
                <Label Text="Profile"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>