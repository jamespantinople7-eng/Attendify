<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.EventDetails"
             Title=""
             BackgroundColor="#EFF6FF">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackground">#EFF6FF</Color>
            <Color x:Key="CardBackground">White</Color>
            <Color x:Key="PrimaryBlue">#4285F4</Color>
            <Color x:Key="DarkNavy">#1F4E8C</Color>
            <Color x:Key="TextDark">#0F172A</Color>
            <Color x:Key="TextMuted">#64748B</Color>
            <Color x:Key="TextLight">#94A3B8</Color>
            <Color x:Key="TextBody">#475569</Color>
            <Color x:Key="Orange">#EC5B13</Color>
            <Color x:Key="OrangeBg">#FFF7ED</Color>
            <Color x:Key="Green">#16A34A</Color>
            <Color x:Key="BorderColor">#F1F5F9</Color>
            <Color x:Key="IconBg">#EFF6FF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Shell.TitleView>
        <Grid ColumnDefinitions="40,*,40"
              VerticalOptions="Center"
              Padding="16,0">
            <!-- Back Button -->
            <Border Grid.Column="0"
                    BackgroundColor="#F1F5F9"
                    StrokeThickness="0"
                    WidthRequest="40"
                    HeightRequest="40"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Image Source="arrow_back.png"
                       WidthRequest="16"
                       HeightRequest="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Title -->
            <Label Grid.Column="1"
                   Text="Event Details"
                   TextColor="Black"
                   FontSize="20"
                   FontFamily="PublicSans-Bold"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*, Auto">

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="0"
                    BackgroundColor="#EFF6FF">
            <VerticalStackLayout Spacing="24"
                                 Padding="16,16,16,16">

                <!-- ── Event Card ── -->
                <Border BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#F1F5F9">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,1"
                                Radius="2"
                                Opacity="0.05"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">

                        <!-- Event Banner Image -->
                        <Image Source="event_banner.png"
                               Aspect="AspectFill"
                               HeightRequest="207"
                               HorizontalOptions="Fill"/>

                        <!-- Event Info -->
                        <VerticalStackLayout Padding="20"
                                             Spacing="20">

                            <!-- Category + Title + Organizer -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Innovation"
                                       TextColor="#4285F4"
                                       FontSize="12"
                                       FontFamily="PublicSans-Bold"
                                       FontAttributes="Bold"
                                       CharacterSpacing="0.6"
                                       TextTransform="Uppercase"/>

                                <Label Text="Tech Innovation Summit 2026"
                                       TextColor="#0F172A"
                                       FontSize="20"
                                       FontFamily="PublicSans-Bold"
                                       FontAttributes="Bold"
                                       LineHeight="1.25"/>

                                <Label Text="Organized by CTU Argao Computing Society"
                                       TextColor="#64748B"
                                       FontSize="14"
                                       FontFamily="PublicSans-Regular"
                                       LineHeight="1.43"/>
                            </VerticalStackLayout>

                            <!-- Meta Info: Date, Location, Slots -->
                            <VerticalStackLayout Spacing="16">

                                <!-- Date Row -->
                                <HorizontalStackLayout Spacing="16">
                                    <Border BackgroundColor="#EFF6FF"
                                            StrokeThickness="0"
                                            WidthRequest="40"
                                            HeightRequest="40">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="calendar_icon.png"
                                               WidthRequest="18"
                                               HeightRequest="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Spacing="0"
                                                         VerticalOptions="Center">
                                        <Label Text="October 24, 2026"
                                               TextColor="#0F172A"
                                               FontSize="14"
                                               FontFamily="PublicSans-SemiBold"
                                               FontAttributes="Bold"/>
                                        <Label Text="09:00 AM - 04:00 PM"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Location Row -->
                                <HorizontalStackLayout Spacing="16">
                                    <Border BackgroundColor="#EFF6FF"
                                            StrokeThickness="0"
                                            WidthRequest="40"
                                            HeightRequest="40">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="location_icon.png"
                                               WidthRequest="16"
                                               HeightRequest="20"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Spacing="0"
                                                         VerticalOptions="Center">
                                        <Label Text="Audio Visual Center"
                                               TextColor="#0F172A"
                                               FontSize="14"
                                               FontFamily="PublicSans-SemiBold"
                                               FontAttributes="Bold"/>
                                        <Label Text="CTU Argao Campus, Cebu"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Slots Row -->
                                <HorizontalStackLayout Spacing="16">
                                    <Border BackgroundColor="#FFF7ED"
                                            StrokeThickness="0"
                                            WidthRequest="40"
                                            HeightRequest="40">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="ticket_icon.png"
                                               WidthRequest="22"
                                               HeightRequest="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Spacing="0"
                                                         VerticalOptions="Center">
                                        <Label Text="15 slots remaining"
                                               TextColor="#EC5B13"
                                               FontSize="14"
                                               FontFamily="PublicSans-SemiBold"
                                               FontAttributes="Bold"/>
                                        <Label Text="Out of 150 total participants"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ── About Event Card ── -->
                <Border BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#F1F5F9"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="0,1"
                                Radius="2"
                                Opacity="0.05"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">
                        <Label Text="About Event"
                               TextColor="#0F172A"
                               FontSize="18"
                               FontFamily="PublicSans-Bold"
                               FontAttributes="Bold"
                               LineHeight="1.56"/>

                        <Label TextColor="#475569"
                               FontSize="14"
                               FontFamily="PublicSans-Regular"
                               LineHeight="1.625">
                            <Label.Text>Join us for the most anticipated technology event of the year! The Tech Innovation Summit 2026 brings together student innovators, industry leaders, and tech enthusiasts to explore the future of computing. Expect hands-on workshops, keynote speeches from top developers, and a networking lounge to connect with peers.</Label.Text>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Bottom spacer so content clears the sticky footer -->
                <BoxView HeightRequest="16"
                         Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Sticky Footer: Status + Register Button ── -->
        <Border Grid.Row="1"
                BackgroundColor="#F2FFFFFF"
                StrokeThickness="0"
                Stroke="Transparent"
                Padding="24,0">
            <Border.StrokeShape>
                <Rectangle/>
            </Border.StrokeShape>
            <!-- Top border line -->
            <Border.Shadow>
                <Shadow Brush="#E2E8F0"
                        Offset="0,-1"
                        Radius="0"
                        Opacity="1"/>
            </Border.Shadow>

            <HorizontalStackLayout Spacing="16"
                                   HeightRequest="71"
                                   VerticalOptions="Center">

                <!-- Status -->
                <VerticalStackLayout Spacing="0"
                                     VerticalOptions="Center">
                    <Label Text="Status"
                           TextColor="#94A3B8"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5"
                           TextTransform="Uppercase"
                           LineHeight="1.5"/>
                    <Label Text="Open Now"
                           TextColor="#16A34A"
                           FontSize="14"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           LineHeight="1.43"/>
                </VerticalStackLayout>

                <!-- Register Button -->
                <Border BackgroundColor="#1F4E8C"
                        StrokeThickness="0"
                        HorizontalOptions="FillAndExpand"
                        HeightRequest="47">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Border.GestureRecognizers>

                    <Label Text="Register for Event"
                           TextColor="White"
                           FontSize="16"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           LineHeight="1.5"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
