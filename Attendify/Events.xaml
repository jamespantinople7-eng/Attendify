<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.Events"
             Title="Campus Events"
             BackgroundColor="#F1F5F9"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryBlue">#1E40AF</Color>
            <Color x:Key="TextDark">#1E293B</Color>
            <Color x:Key="TextMuted">#64748B</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="Academic">#2563EB</Color>
            <Color x:Key="Innovation">#DC2626</Color>
            <Color x:Key="Cultural">#7C3AED</Color>
            <Color x:Key="Workshop">#F59E0B</Color>
            <Color x:Key="Sports">#10B981</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,95">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="16" Padding="16,20,16,16" BackgroundColor="White">

            <!-- Title and Notification -->
            <Grid ColumnDefinitions="*,40">
                <Label Text="Campus Events" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="{StaticResource TextDark}"
                       VerticalOptions="Center" />
                <Image Grid.Column="1" 
                       Source="ic_notification.png" 
                       WidthRequest="24" 
                       HeightRequest="24"
                       HorizontalOptions="End"
                       VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotificationTapped" />
                    </Image.GestureRecognizers>
                </Image>
            </Grid>

            <!-- Search Bar -->
            <Border StrokeShape="RoundRectangle 12" 
                    Stroke="#E2E8F0" 
                    BackgroundColor="#F8FAFC"
                    Padding="12,0">
                <Grid ColumnDefinitions="24,*,24">
                    <Image Grid.Column="0" 
                           Source="ic_search.png" 
                           WidthRequest="20" 
                           HeightRequest="20" 
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1" 
                           Placeholder="Search campus events"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource TextDark}"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Filter Buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Border Grid.Column="0" 
                        StrokeShape="RoundRectangle 20" 
                        Stroke="#E2E8F0" 
                        BackgroundColor="White"
                        Padding="16,10">
                    <Grid ColumnDefinitions="*,16">
                        <Label Grid.Column="0" 
                               Text="Date" 
                               TextColor="{StaticResource TextDark}"
                               VerticalOptions="Center" />
                        <Image Grid.Column="1" 
                               Source="ic_chevron_down.png" 
                               WidthRequest="12" 
                               HeightRequest="12" 
                               VerticalOptions="Center" 
                               HorizontalOptions="End" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDateFilterTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="1" 
                        StrokeShape="RoundRectangle 20" 
                        Stroke="#E2E8F0" 
                        BackgroundColor="White"
                        Padding="16,10">
                    <Grid ColumnDefinitions="*,16">
                        <Label Grid.Column="0" 
                               Text="Category" 
                               TextColor="{StaticResource TextDark}"
                               VerticalOptions="Center" />
                        <Image Grid.Column="1" 
                               Source="ic_chevron_down.png" 
                               WidthRequest="12" 
                               HeightRequest="12" 
                               VerticalOptions="Center" 
                               HorizontalOptions="End" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCategoryFilterTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="2" 
                        StrokeShape="RoundRectangle 20" 
                        Stroke="#E2E8F0" 
                        BackgroundColor="White"
                        Padding="16,10">
                    <Grid ColumnDefinitions="*,16">
                        <Label Grid.Column="0" 
                               Text="Location" 
                               TextColor="{StaticResource TextDark}"
                               VerticalOptions="Center" />
                        <Image Grid.Column="1" 
                               Source="ic_chevron_down.png" 
                               WidthRequest="12" 
                               HeightRequest="12" 
                               VerticalOptions="Center" 
                               HorizontalOptions="End" />
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocationFilterTapped" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <!-- Scrollable Events List -->
        <ScrollView Grid.Row="1" Padding="16,0,16,16">
            <VerticalStackLayout Spacing="16">

                <!-- Event 1: Annual Science Fair 2024 -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="12" Padding="12">
                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    WidthRequest="100" 
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="event_science_fair.png"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="ACADEMIC"
                                       TextColor="{StaticResource Academic}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                                <Label Text="Annual Science Fair 2024"
                                       TextColor="{StaticResource TextDark}"
                                       FontSize="16"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6" Margin="0,4,0,0">
                                    <Image Grid.Column="0" 
                                           Source="ic_calendar_small.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Oct 25, 10:00 AM"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6">
                                    <Image Grid.Column="0" 
                                           Source="ic_location.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Main Hall, Science Building"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Register"
                                BackgroundColor="{StaticResource PrimaryBlue}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Clicked="OnRegisterTapped" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Event 2: Tech Innovation Summit 2026 -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="12" Padding="12">
                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    WidthRequest="100" 
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="event_tech_summit.png"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="INNOVATION"
                                       TextColor="{StaticResource Innovation}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                                <Label Text="Tech Innovation Summit 2026"
                                       TextColor="{StaticResource TextDark}"
                                       FontSize="16"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6" Margin="0,4,0,0">
                                    <Image Grid.Column="0" 
                                           Source="ic_calendar_small.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Oct 24, 09:00 PM"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6">
                                    <Image Grid.Column="0" 
                                           Source="ic_location.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Audio Visual Center"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Register"
                                BackgroundColor="{StaticResource PrimaryBlue}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Clicked="OnRegisterTapped" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Event 3: Spring Music Festival -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="12" Padding="12">
                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    WidthRequest="100" 
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="event_music_festival.png"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="CULTURAL"
                                       TextColor="{StaticResource Cultural}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                                <Label Text="Spring Music Festival"
                                       TextColor="{StaticResource TextDark}"
                                       FontSize="16"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6" Margin="0,4,0,0">
                                    <Image Grid.Column="0" 
                                           Source="ic_calendar_small.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Nov 02, 06:00 PM"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6">
                                    <Image Grid.Column="0" 
                                           Source="ic_location.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="East Campus Plaza"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Waitlist Full"
                                BackgroundColor="#E2E8F0"
                                TextColor="{StaticResource TextMuted}"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                IsEnabled="False" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Event 4: UI/UX Design Masterclass -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="12" Padding="12">
                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    WidthRequest="100" 
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="event_uiux_design.png"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="WORKSHOP"
                                       TextColor="{StaticResource Workshop}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                                <Label Text="UI/UX Design Masterclass"
                                       TextColor="{StaticResource TextDark}"
                                       FontSize="16"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6" Margin="0,4,0,0">
                                    <Image Grid.Column="0" 
                                           Source="ic_calendar_small.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Nov 05, 02:00 PM"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6">
                                    <Image Grid.Column="0" 
                                           Source="ic_location.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Design Lab 402"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Register"
                                BackgroundColor="{StaticResource PrimaryBlue}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Clicked="OnRegisterTapped" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Event 5: Inter-College Basketball Finals -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="False">
                    <VerticalStackLayout Spacing="12" Padding="12">
                        <Grid ColumnDefinitions="100,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                    WidthRequest="100" 
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 8">
                                <Image Source="event_basketball.png"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="SPORTS"
                                       TextColor="{StaticResource Sports}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                                <Label Text="Inter-College Basketball Finals"
                                       TextColor="{StaticResource TextDark}"
                                       FontSize="16"
                                       FontAttributes="Bold" />

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6" Margin="0,4,0,0">
                                    <Image Grid.Column="0" 
                                           Source="ic_calendar_small.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Oct 28, 04:30 PM"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*" ColumnSpacing="6">
                                    <Image Grid.Column="0" 
                                           Source="ic_location.png" 
                                           WidthRequest="14" 
                                           HeightRequest="14" 
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1" 
                                           Text="Campus Arena"
                                           TextColor="{StaticResource TextMuted}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Button Text="Register"
                                BackgroundColor="{StaticResource PrimaryBlue}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontAttributes="Bold"
                                Clicked="OnRegisterTapped" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <!-- Bottom Navigation -->
        <Border Grid.Row="2"
        BackgroundColor="#F2FFFFFF"
        StrokeThickness="0"
        Padding="20,8,20,16"
        HeightRequest="95"
        VerticalOptions="End">

            <Grid ColumnDefinitions="*,*,70,*,*"
          HeightRequest="95"
          VerticalOptions="Center">

                <!-- Home -->
                <VerticalStackLayout Grid.Column="0"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_home.png"
                   WidthRequest="16"
                   HeightRequest="18" />
                    <Label Text="Home"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Events -->
                <VerticalStackLayout Grid.Column="1"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <Image Source="ic_events.png"
                   WidthRequest="18"
                   HeightRequest="20" />
                    <Label Text="Events"
                   TextColor="#1F4E8C"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Scan -->
                <Grid Grid.Column="2"
              HorizontalOptions="Center"
              VerticalOptions="Start"
              ZIndex="10">

                    <Border BackgroundColor="#1F4E8C"
                    StrokeThickness="4"
                    Stroke="White"
                    WidthRequest="60"
                    HeightRequest="60"
                    TranslationY="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanTapped" />
                        </Border.GestureRecognizers>

                        <Image Source="ic_scan.png"
                       WidthRequest="28"
                       HeightRequest="28"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- My Events -->
                <VerticalStackLayout Grid.Column="3"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMyEventsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_myevents.png"
                   WidthRequest="18"
                   HeightRequest="18" />
                    <Label Text="My Events"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Profile -->
                <VerticalStackLayout Grid.Column="4"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_profile.png"
                   WidthRequest="16"
                   HeightRequest="16" />
                    <Label Text="Profile"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>