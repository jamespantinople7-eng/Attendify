<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.ForgotPassword"
             Title="Reset Password"
             BackgroundColor="White">

    <ContentPage.Resources>
        <Color x:Key="Primary">#1F4E8C</Color>
        <Color x:Key="PrimaryDark">#163A6B</Color>
        <Color x:Key="TextPrimary">#1F4E8C</Color>
        <Color x:Key="TextSecondary">#4A4459</Color>
        <Color x:Key="Background">#FFFFFF</Color>
        <Color x:Key="InputBackground">#FFFFFF</Color>
        <Color x:Key="ShadowColor">#3F000000</Color>

        <Shadow x:Key="CardShadow"
                Brush="{StaticResource ShadowColor}"
                Radius="4"
                Offset="0,4"
                Opacity="0.25"/>

        <Style x:Key="InputFieldStyle" TargetType="Border">
            <Setter Property="WidthRequest" Value="310"/>
            <Setter Property="HeightRequest" Value="42"/>
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
            <Setter Property="Shadow" Value="{StaticResource CardShadow}"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="EntryStyle" TargetType="Entry">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
            <Setter Property="PlaceholderColor" Value="#94A3B8"/>
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="VerticalOptions" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="WidthRequest" Value="205"/>
            <Setter Property="HeightRequest" Value="42"/>
            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Shadow" Value="{StaticResource CardShadow}"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <!-- Match the Login/Signup design size for mobile view -->
        <Grid WidthRequest="402" HeightRequest="874" BackgroundColor="{StaticResource Background}">

            <!-- Logo (align similar to Login layout) -->
            <Image Source="https://placehold.co/100x89"
                   WidthRequest="100" HeightRequest="89"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="0,63,0,0"
                   Aspect="AspectFill"/>

            <!-- Title -->
            <Label Text="Forgot Password"
                   FontSize="36"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="0,173,0,0"/>

            <!-- Email Input -->
            <Border Style="{StaticResource InputFieldStyle}"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Margin="0,282,0,0">
                <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            WidthRequest="24" HeightRequest="24"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"/>
                    <Entry Grid.Column="1"
                           x:Name="txtEmail"
                           Placeholder="Enter your email"
                           Keyboard="Email"
                           Style="{StaticResource EntryStyle}"/>
                </Grid>
            </Border>

            <!-- New Password Input -->
            <Border Style="{StaticResource InputFieldStyle}"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Margin="0,356,0,0">
                <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            WidthRequest="24" HeightRequest="24"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"/>
                    <Entry Grid.Column="1"
                           x:Name="txtNewPassword"
                           Placeholder="Enter new password"
                           IsPassword="True"
                           Style="{StaticResource EntryStyle}"/>
                </Grid>
            </Border>

            <!-- Confirm Password Input -->
            <Border Style="{StaticResource InputFieldStyle}"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Margin="0,430,0,0">
                <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            WidthRequest="24" HeightRequest="24"
                            BackgroundColor="Transparent"
                            StrokeShape="RoundRectangle 12"/>
                    <Entry Grid.Column="1"
                           x:Name="txtConfirmPassword"
                           Placeholder="Confirm new password"
                           IsPassword="True"
                           Style="{StaticResource EntryStyle}"/>
                </Grid>
            </Border>

            <!-- Reset Password Button -->
            <Button Text="Reset Password"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Margin="0,499,0,0"
                    Clicked="Reset_Clicked"/>

            <!-- Back to Login -->
            <Label HorizontalOptions="Center"
                   VerticalOptions="Start"
                   Margin="0,558,0,0"
                   WidthRequest="369"
                   HorizontalTextAlignment="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Remember your password? " 
                              TextColor="{StaticResource Primary}" 
                              FontSize="14"/>
                        <Span Text="Log in here" 
                              TextColor="{StaticResource Primary}" 
                              FontSize="14"
                              FontAttributes="Bold"
                              TextDecorations="Underline">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="GoToLogin_Tapped"/>
                            </Span.GestureRecognizers>
                        </Span>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <!-- Bottom Decorative Image -->
            <Image Source="https://placehold.co/600x279"
                   WidthRequest="600" HeightRequest="279"
                   HorizontalOptions="Start"
                   VerticalOptions="End"
                   Margin="-98,0,0,0"
                   Aspect="AspectFill"
                   Opacity="0.3"/>
        </Grid>
    </ScrollView>
</ContentPage>