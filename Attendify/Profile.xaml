<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.Profile"
             Title="Profile"
             BackgroundColor="#EFF6FF"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="HeaderBlue">#2F7CBD</Color>
            <Color x:Key="Navy">#1F4E8C</Color>
            <Color x:Key="TextDark">#0F172A</Color>
            <Color x:Key="TextMuted">#64748B</Color>
            <Color x:Key="AccentBlue">#3B82F6</Color>
            <Color x:Key="Success">#16A34A</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="LightBg">#F8FAFC</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="60,*,71">
        <!-- Header background -->
        <BoxView Grid.Row="0" Color="{StaticResource HeaderBlue}" />

        <!-- Top bar (back, title, settings) -->
        <Grid Grid.Row="0" ColumnDefinitions="48,*,48" Padding="12,18,12,0" VerticalOptions="Start">
            <!-- Back Button - Top Left -->
            <Image Grid.Column="0" Source="ic_back.png" WidthRequest="10" HeightRequest="20" VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>

            <!-- Title - Center -->
            <Label Grid.Column="1"
                   Text="Profile"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold" />

            <!-- Settings Button - Top Right -->
            <Image Grid.Column="2" Source="ic_settings.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="End" VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Image.GestureRecognizers>
            </Image>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="16,0,16,24">

                <!-- Profile card overlapping header -->
                <Frame BackgroundColor="{StaticResource CardBg}"
                       CornerRadius="12"
                       Padding="16"
                       HasShadow="True"
                       Margin="0,-50,0,0">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <!-- avatar with blue ring -->
                        <Grid HorizontalOptions="Center">
                            <Border Stroke="{StaticResource HeaderBlue}" StrokeThickness="4" BackgroundColor="White" Padding="6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="999" />
                                </Border.StrokeShape>
                                <Image Source="profile_photo.png" WidthRequest="92" HeightRequest="92" Aspect="AspectFill" />
                            </Border>
                        </Grid>

                        <Label Text="Patrick Dale"
                               TextColor="{StaticResource TextDark}"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />

                        <Label Text="BS INFORMATION TECHNOLOGY"
                               TextColor="{StaticResource AccentBlue}"
                               FontSize="12"
                               HorizontalOptions="Center" />

                        <Grid ColumnDefinitions="Auto,8,Auto" HorizontalOptions="Center" ColumnSpacing="6">
                            <Image Source="ic_id.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                            <Label Text="2021-00123" TextColor="{StaticResource TextMuted}" FontSize="12" VerticalOptions="Center" />
                        </Grid>

                        <Label Text="dalep@ctu.edu.ph"
                               TextColor="{StaticResource TextMuted}"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Academic Stats header -->
                <Label Text="Academic Stats"
                       TextColor="{StaticResource TextDark}"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="4,4,0,0" />

                <!-- Stats container (card) -->
                <Frame CornerRadius="12" BackgroundColor="White" Padding="6" HasShadow="False">
                    <VerticalStackLayout Spacing="6" Padding="6">
                        <!-- Row 1 -->
                        <Grid ColumnDefinitions="44,*,80" Padding="8" VerticalOptions="Center">
                            <Border BackgroundColor="#EEF7FF" WidthRequest="36" HeightRequest="36" HorizontalOptions="Start" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Image Source="ic_events_registered.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Events Registered" VerticalOptions="Center" TextColor="{StaticResource TextDark}" />
                            <Label Grid.Column="2" Text="15" VerticalOptions="Center" HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F1F5F9" />

                        <!-- Row 2 -->
                        <Grid ColumnDefinitions="44,*,80" Padding="8" VerticalOptions="Center">
                            <Border BackgroundColor="#ECFFF0" WidthRequest="36" HeightRequest="36" HorizontalOptions="Start" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Image Source="ic_events_attended.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" Text="Events Attended" VerticalOptions="Center" TextColor="{StaticResource TextDark}" />
                            <Label Grid.Column="2" Text="12" VerticalOptions="Center" HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F1F5F9" />

                        <!-- Row 3 -->
                        <Grid ColumnDefinitions="44,*,80" Padding="8" VerticalOptions="Center">
                            <Border BackgroundColor="#FFF6EC" WidthRequest="36" HeightRequest="36" HorizontalOptions="Start" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Image Source="ic_attendance.png" WidthRequest="20" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <StackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="Attendance Rate" TextColor="{StaticResource TextDark}" />
                                <ProgressBar Progress="0.8" HeightRequest="6" BackgroundColor="#E6EEF9" ProgressColor="{StaticResource AccentBlue}" />
                            </StackLayout>

                            <Label Grid.Column="2" Text="80%" VerticalOptions="Center" HorizontalOptions="End" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Action buttons side-by-side -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,12">
                    <Button Grid.Column="0"
                            Text="Edit Profile"
                            BackgroundColor="#E8F1FF"
                            TextColor="#2563EB"
                            CornerRadius="10"
                            HeightRequest="44"
                            Clicked="OnEditProfileTapped" />

                    <Button Grid.Column="1"
                            Text="Logout"
                            BackgroundColor="#FFECEC"
                            TextColor="#DC2626"
                            CornerRadius="10"
                            HeightRequest="44"
                            Clicked="OnLogoutTapped" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Border Grid.Row="2"
        BackgroundColor="#F2FFFFFF"
        StrokeThickness="0"
        Padding="20,8,20,16"
        HeightRequest="95"
        VerticalOptions="End">

            <Grid ColumnDefinitions="*,*,70,*,*"
          HeightRequest="95"
          VerticalOptions="Center">

                <!-- Home -->
                <VerticalStackLayout Grid.Column="0"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_home.png"
                   WidthRequest="16"
                   HeightRequest="18" />
                    <Label Text="Home"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Events -->
                <VerticalStackLayout Grid.Column="1"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <Image Source="ic_events.png"
                   WidthRequest="18"
                   HeightRequest="20" />
                    <Label Text="Events"
                   TextColor="#1F4E8C"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Scan -->
                <Grid Grid.Column="2"
              HorizontalOptions="Center"
              VerticalOptions="Start"
              ZIndex="10">

                    <Border BackgroundColor="#1F4E8C"
                    StrokeThickness="4"
                    Stroke="White"
                    WidthRequest="60"
                    HeightRequest="60"
                    TranslationY="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanTapped" />
                        </Border.GestureRecognizers>

                        <Image Source="ic_scan.png"
                       WidthRequest="28"
                       HeightRequest="28"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- My Events -->
                <VerticalStackLayout Grid.Column="3"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMyEventsTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_myevents.png"
                   WidthRequest="18"
                   HeightRequest="18" />
                    <Label Text="My Events"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

                <!-- Profile -->
                <VerticalStackLayout Grid.Column="4"
                             Spacing="2"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Margin="0,18,0,0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="ic_profile.png"
                   WidthRequest="16"
                   HeightRequest="16" />
                    <Label Text="Profile"
                   TextColor="#94A3B8"
                   FontSize="10"
                   FontAttributes="Bold" />
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>