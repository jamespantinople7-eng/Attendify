<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Attendify.Homepage"
             Title=""
             BackgroundColor="#EFF6FF"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Navy">#1F4E8C</Color>
            <Color x:Key="TextDark">#0F172A</Color>
            <Color x:Key="TextMuted">#64748B</Color>
            <Color x:Key="TextBody">#475569</Color>
            <Color x:Key="TextLight">#94A3B8</Color>
            <Color x:Key="Green">#16A34A</Color>
            <Color x:Key="Blue">#3B82F6</Color>
            <Color x:Key="BorderColor">#F1F5F9</Color>
            <Color x:Key="PageBg">#EFF6FF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Root grid: status bar + top bar + body + bottom nav -->
    <Grid RowDefinitions="52, 64, *, 71"
          BackgroundColor="#EFF6FF">

        <!-- ── Status Bar ── -->
        <Grid Grid.Row="0"
              Padding="24,10"
              BackgroundColor="White">
            <Label Text="9:30"
                   TextColor="Black"
                   FontSize="14"
                   FontFamily="Roboto"
                   FontAttributes="Bold"
                   CharacterSpacing="0.14"
                   HorizontalOptions="Start"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- ── Top App Bar ── -->
        <Grid Grid.Row="1"
              BackgroundColor="White"
              Padding="16,0"
              ColumnDefinitions="Auto, *, Auto">

            <!-- Logo + App Name -->
            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="12"
                                   VerticalOptions="Center">
                <Image Source="app_logo.png"
                       WidthRequest="46"
                       HeightRequest="41"
                       Aspect="AspectFit"/>
                <Label Text="Attendify"
                       TextColor="#0F172A"
                       FontSize="20"
                       FontFamily="PublicSans-Bold"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Notification Bell -->
            <Border Grid.Column="2"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    WidthRequest="40"
                    HeightRequest="40"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Image Source="ic_bell.png"
                       WidthRequest="25"
                       HeightRequest="26"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotificationTapped"/>
                    </Image.GestureRecognizers>
                </Image>
            </Border>
        </Grid>

        <!-- ── Scrollable Body ── -->
        <ScrollView Grid.Row="2"
                    BackgroundColor="#EFF6FF">
            <VerticalStackLayout Spacing="16"
                                 Padding="0,0,0,16">

                <!-- Greeting -->
                <VerticalStackLayout Padding="16,16,16,8"
                                     Spacing="2">
                    <Label Text="Good Morning, Patrick Dale!"
                           TextColor="#0F172A"
                           FontSize="24"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           LineHeight="1.33"/>
                    <Label Text="You have 2 events today"
                           TextColor="#64748B"
                           FontSize="14"
                           FontFamily="PublicSans-Regular"
                           LineHeight="1.43"/>
                </VerticalStackLayout>

                <!-- Search Bar -->
                <Border Margin="16,0"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        HeightRequest="48">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="4" Opacity="0.25"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="18,*"
                          ColumnSpacing="12"
                          Padding="16,0">
                        <Image Grid.Column="0"
                               Source="ic_search.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Search events, venues..."
                               TextColor="#6B7280"
                               FontSize="16"
                               FontFamily="PublicSans-Regular"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSearchTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Quick Actions: Register Event + Scan QR -->
                <Grid Margin="16,0"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- Register Event (filled) -->
                    <Border Grid.Column="0"
                            BackgroundColor="#1F4E8C"
                            StrokeThickness="0"
                            HeightRequest="82">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="6" Opacity="0.15"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterEventTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="ic_register.png"
                                   WidthRequest="18"
                                   HeightRequest="20"
                                   HorizontalOptions="Center"/>
                            <Label Text="Register Event"
                                   TextColor="White"
                                   FontSize="14"
                                   FontFamily="PublicSans-Bold"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Scan QR (outlined) -->
                    <Border Grid.Column="1"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#E2E8F0"
                            HeightRequest="82">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanQRTapped"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="ic_qr.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   HorizontalOptions="Center"/>
                            <Label Text="Scan QR"
                                   TextColor="#0F172A"
                                   FontSize="14"
                                   FontFamily="PublicSans-Bold"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Stats Cards: My Events + Attendance -->
                <Grid Margin="16,0"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- My Events Card -->
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#DBEAFE"
                            HeightRequest="118"
                            Padding="17">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="0">
                            <!-- Icon + Active badge -->
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  Margin="0,0,0,8">
                                <Image Grid.Column="0"
                                       Source="ic_calendar_navy.png"
                                       WidthRequest="18"
                                       HeightRequest="20"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#1A3B82F6"
                                        StrokeThickness="0"
                                        Padding="8,2"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999"/>
                                    </Border.StrokeShape>
                                    <Label Text="Active"
                                           TextColor="#1F4E8C"
                                           FontSize="12"
                                           FontFamily="PublicSans-Bold"
                                           FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                            <!-- Label -->
                            <Label Grid.Row="1"
                                   Text="MY EVENTS"
                                   TextColor="#64748B"
                                   FontSize="12"
                                   FontFamily="PublicSans-SemiBold"
                                   CharacterSpacing="0.6"
                                   Margin="0,0,0,4"/>
                            <!-- Value -->
                            <Label Grid.Row="2"
                                   Text="12"
                                   TextColor="#0F172A"
                                   FontSize="24"
                                   FontFamily="PublicSans-Bold"
                                   FontAttributes="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Attendance Card -->
                    <Border Grid.Column="1"
                            BackgroundColor="#F0FDF4"
                            StrokeThickness="1"
                            Stroke="#DCFCE7"
                            HeightRequest="118"
                            Padding="17">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="0">
                            <!-- Icon + On Track badge -->
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  Margin="0,0,0,8">
                                <Image Grid.Column="0"
                                       Source="ic_attendance.png"
                                       WidthRequest="20"
                                       HeightRequest="17"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#DCFCE7"
                                        StrokeThickness="0"
                                        Padding="8,2"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="999"/>
                                    </Border.StrokeShape>
                                    <Label Text="On Track"
                                           TextColor="#16A34A"
                                           FontSize="12"
                                           FontFamily="PublicSans-Bold"
                                           FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                            <!-- Label -->
                            <Label Grid.Row="1"
                                   Text="ATTENDANCE"
                                   TextColor="#64748B"
                                   FontSize="12"
                                   FontFamily="PublicSans-SemiBold"
                                   CharacterSpacing="0.6"
                                   Margin="0,0,0,4"/>
                            <!-- Value -->
                            <Label Grid.Row="2"
                                   Text="94%"
                                   TextColor="#0F172A"
                                   FontSize="24"
                                   FontFamily="PublicSans-Bold"
                                   FontAttributes="Bold"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Upcoming Events Section -->
                <VerticalStackLayout Spacing="16">

                    <!-- Section Header -->
                    <Grid Padding="16,0"
                          ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Upcoming Events"
                               TextColor="#0F172A"
                               FontSize="18"
                               FontFamily="PublicSans-Bold"
                               FontAttributes="Bold"
                               LineHeight="1.56"/>
                        <Label Grid.Column="1"
                               Text="View All"
                               TextColor="#1F4E8C"
                               FontSize="14"
                               FontFamily="PublicSans-SemiBold"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnViewAllTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Event Cards -->
                    <VerticalStackLayout Padding="16,0"
                                         Spacing="16">

                        <!-- Event 1: Tech Symposium 2026 -->
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#F1F5F9"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.05"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEventTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="80,*"
                                  ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        WidthRequest="80"
                                        HeightRequest="80">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Image Source="event_tech.png"
                                           Aspect="AspectFill"
                                           WidthRequest="80"
                                           HeightRequest="80"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Tech Symposium 2026"
                                               TextColor="#0F172A"
                                               FontSize="16"
                                               FontFamily="PublicSans-Bold"
                                               FontAttributes="Bold"
                                               LineHeight="1.25"/>
                                        <Label Text="Convention Center, Hall A"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"
                                               LineHeight="1.33"/>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Spacing="8"
                                                           Margin="0,8,0,0">
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 Color="#3B82F6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="10:00 AM - 04:00 PM"
                                               TextColor="#475569"
                                               FontSize="12"
                                               FontFamily="PublicSans-Medium"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Event 2: UX/UI Design Workshop -->
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#F1F5F9"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.05"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEventTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="80,*"
                                  ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        WidthRequest="80"
                                        HeightRequest="80">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Image Source="event_ux.png"
                                           Aspect="AspectFill"
                                           WidthRequest="80"
                                           HeightRequest="80"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="UX/UI Design Workshop"
                                               TextColor="#0F172A"
                                               FontSize="16"
                                               FontFamily="PublicSans-Bold"
                                               FontAttributes="Bold"
                                               LineHeight="1.25"/>
                                        <Label Text="Creative Hub Studio"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"
                                               LineHeight="1.33"/>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Spacing="8"
                                                           Margin="0,8,0,0">
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 Color="#3B82F6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="Tomorrow, 02:00 PM"
                                               TextColor="#475569"
                                               FontSize="12"
                                               FontFamily="PublicSans-Medium"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Event 3: Startup Pitch Night -->
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#F1F5F9"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.05"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEventTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="80,*"
                                  ColumnSpacing="16">
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        WidthRequest="80"
                                        HeightRequest="80">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Image Source="event_startup.png"
                                           Aspect="AspectFill"
                                           WidthRequest="80"
                                           HeightRequest="80"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Startup Pitch Night"
                                               TextColor="#0F172A"
                                               FontSize="16"
                                               FontFamily="PublicSans-Bold"
                                               FontAttributes="Bold"
                                               LineHeight="1.25"/>
                                        <Label Text="Innovation Park"
                                               TextColor="#64748B"
                                               FontSize="12"
                                               FontFamily="PublicSans-Regular"
                                               LineHeight="1.33"/>
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Spacing="8"
                                                           Margin="0,8,0,0">
                                        <BoxView WidthRequest="10"
                                                 HeightRequest="10"
                                                 Color="#3B82F6"
                                                 VerticalOptions="Center"/>
                                        <Label Text="Oct 24, 06:00 PM"
                                               TextColor="#475569"
                                               FontSize="12"
                                               FontFamily="PublicSans-Medium"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom Navigation Bar ── -->
        <Border Grid.Row="3"
                BackgroundColor="#F2FFFFFF"
                StrokeThickness="0"
                Padding="24,8,24,24">
            <Border.StrokeShape>
                <Rectangle/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#E2E8F0" Offset="0,-1" Radius="0" Opacity="1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,56,*,*"
                  ColumnSpacing="0"
                  HeightRequest="39">

                <!-- Home (active) -->
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Image Source="ic_home.png"
                           WidthRequest="16"
                           HeightRequest="18"
                           HorizontalOptions="Center"/>
                    <Label Text="Home"
                           TextColor="#1F4E8C"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Events -->
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Image Source="ic_events.png"
                           WidthRequest="18"
                           HeightRequest="20"
                           HorizontalOptions="Center"/>
                    <Label Text="Events"
                           TextColor="#94A3B8"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Scan FAB (center raised button) -->
                <Grid Grid.Column="2"
                      HorizontalOptions="Center"
                      VerticalOptions="Start"
                      Margin="0,-28,0,0">
                    <Border BackgroundColor="#1F4E8C"
                            StrokeThickness="4"
                            Stroke="White"
                            WidthRequest="56"
                            HeightRequest="56">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#663B82F6" Offset="0,6" Radius="10" Opacity="0.4"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanTapped"/>
                        </Border.GestureRecognizers>
                        <Image Source="ic_scan.png"
                               WidthRequest="25"
                               HeightRequest="25"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Scan"
                           TextColor="#94A3B8"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="End"
                           Margin="0,0,0,-16"/>
                </Grid>

                <!-- My Events -->
                <VerticalStackLayout Grid.Column="3"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Image Source="ic_myevents.png"
                           WidthRequest="18"
                           HeightRequest="18"
                           HorizontalOptions="Center"/>
                    <Label Text="My Events"
                           TextColor="#94A3B8"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Profile -->
                <VerticalStackLayout Grid.Column="4"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Image Source="ic_profile.png"
                           WidthRequest="16"
                           HeightRequest="16"
                           HorizontalOptions="Center"/>
                    <Label Text="Profile"
                           TextColor="#94A3B8"
                           FontSize="10"
                           FontFamily="PublicSans-Bold"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
